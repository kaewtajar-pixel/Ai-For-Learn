'use client';

import { useState, useEffect } from 'react';
import { api } from '@/lib/api';
import { formatPrice } from '@/lib/utils';
import { TrendingUp, Users, BookOpen, DollarSign, BarChart3 } from 'lucide-react';

export default function AdminAnalytics() {
  const [stats, setStats] = useState<any>(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    Promise.all([api.getDashboard(), api.getEnrollments(), api.getPayments()])
      .then(([dash, enrData, payData]) => {
        const enrollments = enrData?.enrollments || [];
        const payments = payData?.payments || [];

        // Group by month (last 6 months)
        const now = new Date();
        const months = Array.from({ length: 6 }, (_, i) => {
          const d = new Date(now);
          d.setMonth(d.getMonth() - (5 - i));
          return { label: d.toLocaleDateString('th-TH', { month: 'short', year: '2-digit' }), month: d.getMonth(), year: d.getFullYear() };
        });

        const enrollByMonth = months.map(({ label, month, year }) => ({
          label,
          count: enrollments.filter((e: any) => {
            const d = new Date(e.purchaseDate);
            return d.getMonth() === month && d.getFullYear() === year;
          }).length,
        }));

        const revenueByMonth = months.map(({ label, month, year }) => ({
          label,
          amount: payments
            .filter((p: any) => {
              const d = new Date(p.createdAt);
              return p.status === 'approved' && d.getMonth() === month && d.getFullYear() === year;
            })
            .reduce((sum: number, p: any) => sum + (Number(p.amount) || 0), 0),
        }));

        setStats({ ...dash, enrollByMonth, revenueByMonth, enrollments, payments });
      })
      .catch(console.error).finally(() => setLoading(false));
  }, []);

  const maxEnroll = Math.max(...(stats?.enrollByMonth?.map((e: any) => e.count) || [1]), 1);
  const maxRevenue = Math.max(...(stats?.revenueByMonth?.map((e: any) => e.amount) || [1]), 1);

  return (
    <div className="p-6 md:p-8">
      <div className="mb-8">
        <h1 className="text-2xl font-bold text-white">สถิติ</h1>
        <p className="text-slate-400 mt-1">ภาพรวมข้อมูลและแนวโน้ม</p>
      </div>

      {/* Overview */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        {[
          { label: 'คอร์สทั้งหมด', value: stats?.totalCourses || 0, icon: <BookOpen size={20} className="text-blue-400" />, color: 'blue' },
          { label: 'นักเรียนทั้งหมด', value: stats?.totalStudents || 0, icon: <Users size={20} className="text-purple-400" />, color: 'purple' },
          { label: 'การลงทะเบียน', value: stats?.enrollments?.length || 0, icon: <TrendingUp size={20} className="text-emerald-400" />, color: 'green' },
          { label: 'รายได้รวม', value: formatPrice(stats?.totalRevenue || 0), icon: <DollarSign size={20} className="text-pink-400" />, color: 'pink' },
        ].map((s) => (
          <div key={s.label} className="glass-card p-5">
            <div className="mb-2">{s.icon}</div>
            <div className="text-2xl font-bold text-white">{s.value}</div>
            <div className="text-slate-400 text-sm">{s.label}</div>
          </div>
        ))}
      </div>

      <div className="grid lg:grid-cols-2 gap-6">
        {/* Enrollment chart */}
        <div className="glass-card p-6">
          <div className="flex items-center gap-2 mb-6">
            <BarChart3 size={18} className="text-blue-400" />
            <h2 className="text-white font-semibold">การลงทะเบียน 6 เดือนล่าสุด</h2>
          </div>
          {loading ? (
            <div className="h-40 flex items-center justify-center text-slate-500">กำลังโหลด...</div>
          ) : (
            <div className="flex items-end gap-3 h-40">
              {stats?.enrollByMonth?.map((m: any, i: number) => (
                <div key={i} className="flex-1 flex flex-col items-center gap-2">
                  <span className="text-slate-400 text-xs">{m.count}</span>
                  <div className="w-full rounded-t-lg bg-gradient-to-t from-blue-600 to-blue-400 transition-all"
                    style={{ height: `${Math.max((m.count / maxEnroll) * 120, m.count > 0 ? 8 : 2)}px` }} />
                  <span className="text-slate-500 text-xs">{m.label}</span>
                </div>
              ))}
            </div>
          )}
        </div>

        {/* Revenue chart */}
        <div className="glass-card p-6">
          <div className="flex items-center gap-2 mb-6">
            <DollarSign size={18} className="text-emerald-400" />
            <h2 className="text-white font-semibold">รายได้ 6 เดือนล่าสุด</h2>
          </div>
          {loading ? (
            <div className="h-40 flex items-center justify-center text-slate-500">กำลังโหลด...</div>
          ) : (
            <div className="flex items-end gap-3 h-40">
              {stats?.revenueByMonth?.map((m: any, i: number) => (
                <div key={i} className="flex-1 flex flex-col items-center gap-2">
                  <span className="text-slate-400 text-xs">{m.amount > 0 ? `${(m.amount / 1000).toFixed(1)}K` : '0'}</span>
                  <div className="w-full rounded-t-lg bg-gradient-to-t from-emerald-600 to-emerald-400 transition-all"
                    style={{ height: `${Math.max((m.amount / maxRevenue) * 120, m.amount > 0 ? 8 : 2)}px` }} />
                  <span className="text-slate-500 text-xs">{m.label}</span>
                </div>
              ))}
            </div>
          )}
        </div>

        {/* Payment status breakdown */}
        <div className="glass-card p-6">
          <h2 className="text-white font-semibold mb-5">สถานะการชำระเงิน</h2>
          {['approved', 'pending', 'rejected'].map((status) => {
            const count = stats?.payments?.filter((p: any) => p.status === status).length || 0;
            const total = stats?.payments?.length || 1;
            const pct = Math.round((count / total) * 100);
            return (
              <div key={status} className="mb-4">
                <div className="flex justify-between text-sm mb-1">
                  <span className="text-slate-400">{status === 'approved' ? 'อนุมัติ' : status === 'pending' ? 'รอตรวจ' : 'ปฏิเสธ'}</span>
                  <span className="text-white">{count} ({pct}%)</span>
                </div>
                <div className="progress-bar">
                  <div className={`progress-fill ${status === 'approved' ? 'bg-emerald-500' : status === 'pending' ? 'bg-yellow-500' : 'bg-red-500'}`}
                    style={{ width: `${pct}%`, background: status === 'approved' ? '#10b981' : status === 'pending' ? '#eab308' : '#ef4444' }} />
                </div>
              </div>
            );
          })}
        </div>

        {/* Courses by status */}
        <div className="glass-card p-6">
          <h2 className="text-white font-semibold mb-5">สถานะคอร์ส</h2>
          <div className="space-y-4">
            {[
              { label: 'เผยแพร่แล้ว', count: stats?.latestCourses?.filter((c: any) => c.status === 'published').length || 0, color: '#10b981' },
              { label: 'ซ่อนอยู่', count: stats?.latestCourses?.filter((c: any) => c.status === 'hidden').length || 0, color: '#6366f1' },
            ].map((item) => (
              <div key={item.label} className="flex items-center justify-between">
                <div className="flex items-center gap-3">
                  <div className="w-3 h-3 rounded-full" style={{ background: item.color }} />
                  <span className="text-slate-300 text-sm">{item.label}</span>
                </div>
                <span className="text-white font-semibold">{item.count}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
}
