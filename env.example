'use client';

import { useState, useEffect } from 'react';
import Link from 'next/link';
import Navbar from '@/components/layout/Navbar';
import CourseCard from '@/components/ui/CourseCard';
import { SkeletonCard } from '@/components/ui/Skeleton';
import { api } from '@/lib/api';
import { Course } from '@/types';
import { BookOpen, Zap, Shield, TrendingUp, ArrowRight, Star, Users, PlayCircle, ChevronDown } from 'lucide-react';

export default function HomePage() {
  const [courses, setCourses] = useState<Course[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    api.getCourses()
      .then((data) => setCourses(data?.courses?.filter((c: Course) => c.status === 'published').slice(0, 6) || []))
      .catch(() => setCourses([]))
      .finally(() => setLoading(false));
  }, []);

  return (
    <div className="min-h-screen gradient-hero">
      <Navbar />

      {/* Hero */}
      <section className="pt-32 pb-24 px-4 relative overflow-hidden">
        {/* BG blobs */}
        <div className="absolute top-20 left-10 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl pointer-events-none" />
        <div className="absolute bottom-10 right-10 w-80 h-80 bg-indigo-600/10 rounded-full blur-3xl pointer-events-none" />
        
        <div className="max-w-7xl mx-auto text-center relative">
          <div className="inline-flex items-center gap-2 badge badge-blue mb-6 text-sm px-4 py-2">
            <Zap size={14} fill="currentColor" />
            แพลตฟอร์มการเรียนรู้ AI อันดับ 1 ของไทย
          </div>

          <h1 className="text-5xl md:text-7xl font-bold text-white mb-6 leading-tight">
            เรียนรู้ AI ได้ทุกวัน<br />
            <span className="gradient-text">สร้างทักษะที่ใช้ได้จริง</span>
          </h1>

          <p className="text-slate-400 text-xl max-w-2xl mx-auto mb-10">
            คอร์สเรียน AI คุณภาพสูง ออกแบบโดยผู้เชี่ยวชาญ เรียนได้ทุกที่ทุกเวลา พร้อมใบเซอร์ติฟิเคต
          </p>

          <div className="flex flex-col sm:flex-row gap-4 justify-center mb-16">
            <Link href="/courses" className="btn-primary text-lg px-8 py-4">
              <PlayCircle size={20} />
              ดูคอร์สทั้งหมด
            </Link>
            <Link href="/register" className="btn-secondary text-lg px-8 py-4">
              สมัครฟรีเลย
              <ArrowRight size={20} />
            </Link>
          </div>

          {/* Stats */}
          <div className="flex flex-wrap justify-center gap-8 text-center">
            {[
              { val: '50+', label: 'คอร์สเรียน' },
              { val: '10,000+', label: 'นักเรียน' },
              { val: '4.9', label: 'คะแนนเฉลี่ย', icon: <Star size={14} fill="currentColor" className="text-yellow-400" /> },
              { val: '95%', label: 'อัตราความพึงพอใจ' },
            ].map((s) => (
              <div key={s.label} className="glass-card px-6 py-4">
                <div className="flex items-center gap-1 justify-center text-2xl font-bold text-white">
                  {s.icon}{s.val}
                </div>
                <div className="text-slate-400 text-sm mt-1">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Features */}
      <section className="py-20 px-4">
        <div className="max-w-7xl mx-auto">
          <div className="text-center mb-12">
            <h2 className="text-3xl md:text-4xl font-bold text-white mb-4">
              ทำไมต้องเลือก <span className="gradient-text">AI For Learn?</span>
            </h2>
            <p className="text-slate-400 max-w-xl mx-auto">เราออกแบบทุกอย่างมาเพื่อให้คุณเรียนรู้ได้อย่างมีประสิทธิภาพสูงสุด</p>
          </div>

          <div className="grid md:grid-cols-3 gap-6">
            {[
              {
                icon: <BookOpen size={24} className="text-blue-400" />,
                title: 'เนื้อหาคุณภาพสูง',
                desc: 'คอร์สเรียนออกแบบโดยผู้เชี่ยวชาญ AI ระดับประเทศ อัพเดทเนื้อหาอยู่เสมอ'
              },
              {
                icon: <TrendingUp size={24} className="text-emerald-400" />,
                title: 'ติดตามความก้าวหน้า',
                desc: 'ระบบติดตามการเรียนรู้อัตโนมัติ รู้ว่าคุณเรียนไปถึงไหนแล้วตลอดเวลา'
              },
              {
                icon: <Shield size={24} className="text-purple-400" />,
                title: 'รับประกันความพึงพอใจ',
                desc: 'หากไม่พอใจภายใน 30 วัน คืนเงิน 100% โดยไม่มีคำถาม'
              },
            ].map((f) => (
              <div key={f.title} className="glass-card p-6 hover:border-blue-500/20 transition-all">
                <div className="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center mb-4">
                  {f.icon}
                </div>
                <h3 className="text-white font-semibold mb-2">{f.title}</h3>
                <p className="text-slate-400 text-sm">{f.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Courses */}
      <section className="py-20 px-4">
        <div className="max-w-7xl mx-auto">
          <div className="flex items-center justify-between mb-10">
            <div>
              <h2 className="text-3xl font-bold text-white mb-2">คอร์สแนะนำ</h2>
              <p className="text-slate-400">เริ่มต้นการเรียนรู้ AI วันนี้</p>
            </div>
            <Link href="/courses" className="btn-secondary hidden sm:flex">
              ดูทั้งหมด <ArrowRight size={16} />
            </Link>
          </div>

          {loading ? (
            <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {Array.from({ length: 3 }).map((_, i) => <SkeletonCard key={i} />)}
            </div>
          ) : courses.length > 0 ? (
            <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {courses.map((course) => (
                <CourseCard key={course.courseId} course={course} />
              ))}
            </div>
          ) : (
            <div className="text-center py-20 glass-card">
              <BookOpen size={48} className="text-slate-600 mx-auto mb-4" />
              <p className="text-slate-400">ยังไม่มีคอร์สในขณะนี้</p>
              <p className="text-slate-500 text-sm mt-1">กรุณาตรวจสอบการตั้งค่า Google Apps Script</p>
            </div>
          )}
        </div>
      </section>

      {/* CTA Banner */}
      <section className="py-20 px-4">
        <div className="max-w-4xl mx-auto">
          <div className="glass-card p-12 text-center relative overflow-hidden">
            <div className="absolute inset-0 bg-gradient-to-r from-blue-600/10 to-indigo-600/10" />
            <div className="relative">
              <h2 className="text-3xl md:text-4xl font-bold text-white mb-4">
                พร้อมเริ่มต้นการเรียนรู้แล้วหรือยัง?
              </h2>
              <p className="text-slate-400 mb-8">สมัครฟรี และเริ่มเรียน AI วันนี้เลย</p>
              <Link href="/register" className="btn-primary text-lg px-10 py-4">
                สมัครสมาชิกฟรี
                <ArrowRight size={20} />
              </Link>
            </div>
          </div>
        </div>
      </section>

      {/* Footer */}
      <footer className="border-t border-white/5 py-10 px-4">
        <div className="max-w-7xl mx-auto text-center text-slate-500 text-sm">
          <p>© 2024 AI For Learn Everyday. สงวนลิขสิทธิ์ทุกประการ</p>
        </div>
      </footer>
    </div>
  );
}
